{
  "mcpServers": {
    "context7": {
      "autoApprove": [
        "resolve-library-id",
        "query-docs"
      ],
      "disabled": false,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "type": "streamable-http",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "autoApprove": [
        "web_search_exa",
        "web_fetch_exa"
      ],
      "headers": {
        "Authorization": "${EXA_API_KEY}"
      },
      "type": "http",
      "url": "https://mcp.exa.ai/mcp"
    },
    "fetch": {
      "args": [
        "mcp-server-fetch"
      ],
      "autoApprove": [
        "fetch"
      ],
      "command": "uvx"
    },
    "jina-mcp-server": {
      "autoApprove": [
        "show_api_key",
        "primer",
        "guess_datetime_url",
        "capture_screenshot_url",
        "read_url",
        "search_web",
        "expand_query",
        "search_arxiv",
        "search_ssrn",
        "search_jina_blog",
        "search_images",
        "parallel_search_web",
        "parallel_search_arxiv",
        "parallel_search_ssrn",
        "parallel_read_url",
        "classify_text",
        "sort_by_relevance",
        "deduplicate_strings",
        "deduplicate_images",
        "search_bibtex",
        "extract_pdf"
      ],
      "headers": {
        "Authorization": "${JINA_API_KEY}"
      },
      "type": "http",
      "url": "https://mcp.jina.ai/v1"
    },
    "playwright": {
      "args": [
        "@playwright/mcp@latest"
      ],
      "autoApprove": [
        "browser_close",
        "browser_resize",
        "browser_console_messages",
        "browser_handle_dialog",
        "browser_evaluate",
        "browser_file_upload",
        "browser_drop",
        "browser_fill_form",
        "browser_press_key",
        "browser_type",
        "browser_navigate",
        "browser_navigate_back",
        "browser_network_requests",
        "browser_network_request",
        "browser_run_code_unsafe",
        "browser_take_screenshot",
        "browser_snapshot",
        "browser_click",
        "browser_drag",
        "browser_hover",
        "browser_select_option",
        "browser_tabs",
        "browser_wait_for"
      ],
      "command": "npx",
      "type": "stdio"
    },
    "sequentialthinking": {
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "autoApprove": [
        "sequentialthinking"
      ],
      "command": "npx"
    }
  },
  "nativeMCPServers": {
    "neovim": {
      "disabled_prompts": [
        "parrot"
      ]
    }
  }
}
